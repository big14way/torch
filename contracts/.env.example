# Deployer / owner key (Coston2 only; never commit a real key)
PRIVATE_KEY=

# Coston2 RPC (default is fine)
COSTON2_RPC=https://coston2-api.flare.network/ext/C/rpc

# Testnet FXRP token address on Coston2.
# Get testnet FXRP from the Coston2 faucet: https://faucet.flare.network
# Then read the token contract address from the faucet tx or Coston2 explorer.
FXRP_ADDRESS=

# Run `npm run resolve:ftso` to fill this (dynamic FlareContractRegistry lookup)
FTSOV2_ADDRESS=

# Address of the agent (TEE identity in production). Defaults to deployer.
EXECUTOR_ADDRESS=
