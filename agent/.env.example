# ---- shared ----
# RPC of the chain where TorchVault lives
RPC_URL=http://127.0.0.1:8545

# Executor key. Local default is Hardhat account #1 (public dev key, no value).
# In production this key is generated INSIDE the TEE and never leaves it.
EXECUTOR_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d

# mock  -> fills at the FTSO mark, no external calls (full local e2e)
# testnet -> routes orders to Hyperliquid testnet (needs HL_PRIVATE_KEY)
EXECUTION_MODE=mock

# Random-walks the MockFtsoV2 prices so the local demo moves. auto = on when
# mode is mock and chain is 31337.
PRICE_WALK=auto

# ---- Hyperliquid testnet mode ----
# API wallet key authorized on your Hyperliquid TESTNET account.
# API wallets can trade but CANNOT withdraw. Create at:
# https://app.hyperliquid-testnet.xyz/API
# Faucet (1,000 mock USDC) requires a prior mainnet deposit from the same
# address: https://app.hyperliquid-testnet.xyz/drip
HL_PRIVATE_KEY=
HL_API_URL=https://api.hyperliquid-testnet.xyz
